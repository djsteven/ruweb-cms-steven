APP_NAME=Flaxt
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flaxt_cms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo (optional fallback; admin UI is the source of truth)
BREVO_API_KEY=

VITE_APP_NAME="${APP_NAME}"

# CMS Configuration
CMS_ADMIN_NAME=Admin
CMS_ADMIN_EMAIL=admin@flaxt.local
CMS_ADMIN_PASSWORD=password
CMS_UPLOAD_MAX_SIZE=10240
CMS_IMAGE_MAX_SIZE=5120
CMS_DOCUMENT_MAX_SIZE=10240
